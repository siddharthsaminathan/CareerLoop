# career-ops / CareerLoop — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit your actual .env file. It is already in .gitignore.

# ── Supabase — Database + Auth ───────────────────────────────────────────────
# DATABASE_URL: Supabase connection string (postgres://...)
DATABASE_URL=your_supabase_postgres_url_here

# SUPABASE_JWT_SECRET: Used by the FastAPI backend to verify Supabase-issued JWTs
# Get it: Supabase dashboard → Settings → API → JWT Secret
# Required for careerloop_api/ to accept Google OAuth tokens from the frontend.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── DeepSeek — Primary LLM for job scoring & extraction ──────────────────────
# Used by: careerloop/india_fit_llm.py (scoring) + careerloop/sources/scrapegraph_adapter.py (extraction)
# Get your key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API base URL (only change if using a proxy or self-hosted endpoint)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Model overrides (optional) ────────────────────────────────────────────────
# Defaults are set in config/models.yml. Override here to switch models without
# editing code.
#
# Fit scoring model (india_fit_llm.py):
# CAREERLOOP_FIT_MODEL=deepseek-chat
#
# Extraction model (scrapegraph_adapter.py):
# CAREERLOOP_SCRAPE_MODEL=deepseek/deepseek-chat

# ── Gemini Integration ────────────────────────────────────────────────────────
# Used by: node gemini-eval.mjs  (career-ops slash commands)
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.0-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# Override default Gemini model (optional):
# GEMINI_MODEL=gemini-2.0-flash

# ── SerpAPI — Phase A company discovery + LinkedIn-first onboarding ───────────
# Used by:
#   - careerloop/sources/company_discovery.py (SerpAPIDiscovery) — company search
#   - careerloop/sources/identity_provider.py (LinkedInIdentityProvider) —
#     "find me on LinkedIn" onboarding via Google search + name-match filtering
# When set: enables LinkedIn-first onboarding (name → profile → "Is this you?")
# When absent: company discovery falls back to DDG; onboarding falls back to CV-first
# Get your key: https://serpapi.com/manage-api-key
SERPAPI_KEY=your_serpapi_key_here

# ── Telegram Bot — Multi-User Transport ──────────────────────────────────────
# Required for the webhook server (careerloop/transport/webhook_server.py)
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Public HTTPS URL where the webhook server is reachable (for webhook registration)
# Example: https://your-app.railway.app
WEBHOOK_PUBLIC_URL=https://your-domain.com

# ── Database — Supabase PostgreSQL ────────────────────────────────────────────
# Required for all DB operations (Supabase connection string)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Optional future integrations ─────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Phase A employer discovery (slow). Leave false for fast scans.
ENABLE_PHASE_A=false
